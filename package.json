{
  "name": "cfml-refactor",
  "displayName": "CFML Refactor",
  "description": "Detect and (eventually) refactor database queries in CFML files.",
  "version": "0.1.0",
  "publisher": "cfml-refactor",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:cfml",
    "onLanguage:html"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cfml-refactor.detectQueries",
        "title": "CFML Refactor: Detect Queries"
      },
      {
        "command": "cfml-refactor.convertQueriesInPlace",
        "title": "CFML Refactor: Convert Queries In Place"
      },
      {
        "command": "cfml-refactor.hoistQueries",
        "title": "CFML Refactor: Hoist Queries"
      },
      {
        "command": "cfml-refactor.indexWorkspace",
        "title": "CFML Refactor: Index Workspace"
      },
      {
        "command": "cfml-refactor.findSimilarQueries",
        "title": "CFML Refactor: Find Similar Queries"
      }
    ],
    "configuration": {
      "title": "CFML Refactor",
      "properties": {
        "cfml-refactor.indexOnActivation": {
          "type": "boolean",
          "default": true,
          "description": "Build query index when extension activates if missing"
        },
        "cfml-refactor.normalizeIdentifierCase": {
          "type": "boolean",
          "default": false,
          "description": "Treat identifier case as insignificant during matching"
        },
        "cfml-refactor.stripTableAliases": {
          "type": "boolean",
          "default": false,
          "description": "Strip single-letter table aliases during normalization"
        },
        "cfml-refactor.suggestSimilarQueries": {
          "type": "boolean",
          "default": false,
          "description": "Surface TABLE-OVERLAP matches in addition to EXACT/STRUCTURAL"
        },
        "cfml-refactor.indexExclude": {
          "type": "array",
          "default": ["node_modules", "dist", "build", ".git"],
          "description": "Glob patterns to exclude from indexing"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "compile-tests": "tsc -p ./tsconfig.test.json",
    "pretest": "npm run compile-tests",
    "test": "mocha \"out-test/test/**/*.test.js\"",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "mocha": "^10.3.0",
    "typescript": "^5.4.0"
  }
}
